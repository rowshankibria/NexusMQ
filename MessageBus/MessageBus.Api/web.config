<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- ASP.NET Core Module for IIS Hosting -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <!-- ASP.NET Core Hosting Configuration -->
      <aspNetCore processPath="dotnet"
                  arguments=".\MessageBus.Api.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="InProcess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Connection string should be configured in IIS Application Pool or Azure Key Vault -->
          <!-- <environmentVariable name="ConnectionStrings__MessageBusDb" value="..." /> -->
        </environmentVariables>
      </aspNetCore>

      <!-- Security Headers -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <add name="X-Frame-Options" value="DENY" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-XSS-Protection" value="1; mode=block" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
          <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' wss:;" />
        </customHeaders>
      </httpProtocol>

      <!-- Compression -->
      <urlCompression doStaticCompression="true" doDynamicCompression="true" />

      <!-- Static Content Caching -->
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
      </staticContent>

      <!-- Request Filtering -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="104857600" /> <!-- 100 MB -->
          <verbs>
            <add verb="OPTIONS" allowed="true" />
          </verbs>
        </requestFiltering>
      </security>

      <!-- URL Rewrite for SignalR WebSockets -->
      <rewrite>
        <rules>
          <rule name="WebSocket" enabled="true" stopProcessing="true">
            <match url="^messagebushub" />
            <conditions>
              <add input="{HTTP_UPGRADE}" pattern="websocket" />
            </conditions>
            <action type="None" />
          </rule>
        </rules>
      </rewrite>

      <!-- WebSocket Configuration -->
      <webSocket enabled="true" />

    </system.webServer>
  </location>

  <!-- Application-specific settings can be added here -->
  <appSettings>
    <!-- Ensure logs directory exists -->
  </appSettings>
</configuration>
<!--
IIS Deployment Notes:
=====================

1. Prerequisites:
   - Install .NET 8.0 Hosting Bundle: https://dotnet.microsoft.com/download/dotnet/8.0
   - Enable WebSocket Protocol in IIS Features
   - Install URL Rewrite Module (optional, for advanced routing)

2. Application Pool Settings:
   - .NET CLR Version: No Managed Code
   - Managed Pipeline Mode: Integrated
   - Identity: ApplicationPoolIdentity or specific service account
   - Start Mode: AlwaysRunning (recommended for SignalR)
   - Idle Time-out: 0 (disable idle timeout for SignalR)

3. Site Settings:
   - Physical Path: Point to published output folder
   - Application Pool: Select the pool created above
   - Bindings: Configure HTTPS with valid certificate

4. Folder Permissions:
   - Grant IIS_IUSRS read access to application folder
   - Grant IIS_IUSRS write access to logs folder

5. SSL/TLS:
   - Use TLS 1.2 or higher
   - Configure HTTPS binding with valid certificate
   - Consider using HSTS

6. Environment Variables:
   - Configure ConnectionStrings__MessageBusDb in Application Pool
   - Or use Azure Key Vault for secrets management

7. Health Check:
   - Configure IIS Health Check to /api/health
   - Set appropriate timeout values

8. Logging:
   - Create 'logs' folder in application root
   - Grant write permissions to application pool identity
   - Consider using centralized logging (ELK, Application Insights)
-->

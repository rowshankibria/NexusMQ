{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MessageBusDb": "Server=STAGING-SQL-SERVER;Database=MessageBus_Staging;User Id=messagebus_app;Password=CHANGE_ME_IN_ENVIRONMENT;TrustServerCertificate=True;Encrypt=True;Connection Timeout=30;"
  },
  "ApiKey": {
    "Enabled": true,
    "ValidKeys": [
      {
        "Name": "Staging-Admin",
        "Key": "CHANGE_ME_STAGING_ADMIN_KEY",
        "IsActive": true,
        "Permissions": [ "*" ]
      },
      {
        "Name": "Staging-Operator",
        "Key": "CHANGE_ME_STAGING_OPERATOR_KEY",
        "IsActive": true,
        "Permissions": [ "read", "write" ]
      },
      {
        "Name": "Staging-ReadOnly",
        "Key": "CHANGE_ME_STAGING_READONLY_KEY",
        "IsActive": true,
        "Permissions": [ "read" ]
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "https://messagebus-staging.conedison.com",
      "https://staging.messagebus.internal"
    ]
  },
  "SignalR": {
    "EnableDetailedErrors": true,
    "MaximumReceiveMessageSize": 65536,
    "ClientTimeoutInterval": "00:01:00",
    "KeepAliveInterval": "00:00:15"
  },
  "HealthMonitor": {
    "IntervalSeconds": 30,
    "Enabled": true
  },
  "MetricsCollection": {
    "IntervalSeconds": 60,
    "RetentionDays": 30,
    "Enabled": true
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error",
      "MessageBus": "Information"
    }
  },
  "AllowedHosts": "messagebus.conedison.com;*.messagebus.internal",
  "ConnectionStrings": {
    "MessageBusDb": "Server=PROD-SQL-SERVER;Database=MessageBus;User Id=messagebus_app;Password=CHANGE_ME_USE_AZURE_KEY_VAULT;TrustServerCertificate=False;Encrypt=True;Connection Timeout=30;MultipleActiveResultSets=True;"
  },
  "ApiKey": {
    "Enabled": true,
    "ValidKeys": []
  },
  "Cors": {
    "AllowedOrigins": [
      "https://messagebus.conedison.com",
      "https://messagebus.internal"
    ]
  },
  "SignalR": {
    "EnableDetailedErrors": false,
    "MaximumReceiveMessageSize": 65536,
    "ClientTimeoutInterval": "00:01:00",
    "KeepAliveInterval": "00:00:15"
  },
  "HealthMonitor": {
    "IntervalSeconds": 30,
    "Enabled": true
  },
  "MetricsCollection": {
    "IntervalSeconds": 60,
    "RetentionDays": 90,
    "Enabled": true
  },
  "Security": {
    "RequireHttps": true,
    "HstsEnabled": true,
    "HstsMaxAgeDays": 365
  }
}

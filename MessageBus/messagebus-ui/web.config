<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Configure static content handling -->
    <staticContent>
      <!-- Add MIME types for Angular assets -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />

      <!-- Cache static assets -->
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- URL Rewrite for Angular SPA routing -->
    <rewrite>
      <rules>
        <!-- Don't rewrite requests to API -->
        <rule name="API Requests" stopProcessing="true">
          <match url="^api/(.*)$" />
          <action type="None" />
        </rule>

        <!-- Don't rewrite requests to SignalR hub -->
        <rule name="SignalR Hub" stopProcessing="true">
          <match url="^messagebushub(.*)$" />
          <action type="None" />
        </rule>

        <!-- Don't rewrite requests for static files -->
        <rule name="Static Files" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Rewrite all other requests to index.html for Angular routing -->
        <rule name="Angular Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security Headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
        <!-- CSP - Adjust as needed for your specific requirements -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' wss: https:;" />
      </customHeaders>
    </httpProtocol>

    <!-- Compression -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- HTTP Compression settings -->
    <httpCompression>
      <dynamicTypes>
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="text/css" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
      </staticTypes>
    </httpCompression>

    <!-- Default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Custom error pages -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" prefixLanguageFilePath="" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>

  </system.webServer>

  <!-- Cache profiles for different content types -->
  <system.web>
    <caching>
      <outputCacheSettings>
        <outputCacheProfiles>
          <add name="StaticContent" duration="86400" varyByParam="none" />
        </outputCacheProfiles>
      </outputCacheSettings>
    </caching>
  </system.web>
</configuration>
<!--
IIS Deployment Notes for Angular SPA:
=====================================

1. Prerequisites:
   - Install URL Rewrite Module 2.1: https://www.iis.net/downloads/microsoft/url-rewrite
   - Enable Static Content Compression in IIS Features

2. Deployment Steps:
   a. Build the Angular application:
      ng build --configuration production

   b. Copy contents of dist/messagebus-ui/browser/ to IIS website folder

   c. Copy this web.config to the website root

   d. Ensure index.html is present

3. Folder Structure on Server:
   wwwroot/
   ├── index.html
   ├── main.js (hashed)
   ├── polyfills.js (hashed)
   ├── styles.css (hashed)
   ├── assets/
   ├── favicon.ico
   └── web.config

4. IIS Site Settings:
   - Application Pool: No Managed Code
   - Physical Path: Point to dist folder contents
   - Bindings: Configure HTTPS with valid certificate

5. Reverse Proxy to API (if separate):
   If API is hosted separately, configure reverse proxy:

   <rule name="API Reverse Proxy" stopProcessing="true">
     <match url="^api/(.*)$" />
     <action type="Rewrite" url="https://api-server.internal/api/{R:1}" />
   </rule>

6. SSL/TLS:
   - Use TLS 1.2 or higher
   - Configure HTTPS binding
   - Consider HTTP to HTTPS redirect

7. Performance:
   - Enable output caching
   - Configure CDN for static assets (optional)
   - Enable HTTP/2

8. Health Check:
   - Configure IIS health check to /
   - Angular app should load successfully
-->
